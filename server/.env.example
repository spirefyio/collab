# Spirefy collab server — environment configuration template.
# Copy to `.env` for local dev. `.env` is gitignored.

# --- network -----------------------------------------------------------------
COLLAB_LISTEN_ADDR=:8443
COLLAB_PRODUCTION=0

# --- database (required when COLLAB_PRODUCTION=1) ---------------------------
COLLAB_DATABASE_URL=postgres://collab:collab@localhost:5432/collab?sslmode=disable

# --- JWT auth (required when COLLAB_PRODUCTION=1) ---------------------------
# >= 32 random bytes. Generate with:
#   openssl rand -base64 32
COLLAB_JWT_SECRET=
COLLAB_JWT_ISSUER=spirefyio/collab
COLLAB_JWT_AUDIENCE=spirefy-collab-clients
COLLAB_JWT_TTL=24h

# --- OAuth (Google + GitHub) ------------------------------------------------
# Required when COLLAB_PRODUCTION=1 for end-to-end auth.
COLLAB_OAUTH_REDIRECT_BASE_URL=
COLLAB_OAUTH_GOOGLE_CLIENT_ID=
COLLAB_OAUTH_GOOGLE_CLIENT_SECRET=
COLLAB_OAUTH_GITHUB_CLIENT_ID=
COLLAB_OAUTH_GITHUB_CLIENT_SECRET=

# --- WebSocket relay tuning -------------------------------------------------
COLLAB_WS_READ_BUFFER_BYTES=4096
COLLAB_WS_WRITE_BUFFER_BYTES=4096
